# KOMPAGNON Backend Environment Variables
# Copy to .env and fill in actual values

# Database
DATABASE_URL=sqlite:///./kompagnon.db
# For PostgreSQL (production): postgresql://user:password@localhost/kompagnon_db

# KI & APIs
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_PAGESPEED_API_KEY=AIza...

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=info@kompagnon.de
USE_MOCK_EMAIL=false

# Application Settings
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Scheduler
SCHEDULER_TIMEZONE=Europe/Berlin
